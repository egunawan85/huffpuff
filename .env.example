# Server (Gateway)
PORT=3000

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
CALLBACK_URL=https://thehuffandpuff.com/auth/google/callback

# Session
SESSION_SECRET=change-me-in-production

# Fly.io
FLY_API_TOKEN=your-fly-api-token
FLY_APP_NAME=huffpuff-workspaces
FLY_IMAGE=registry.fly.io/huffpuff-workspaces:latest
FLY_REGION=sjc

# Idle timeout (minutes before stopping unused workspace)
IDLE_TIMEOUT_MINUTES=30
